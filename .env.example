
# ─────────────────────────────────────────────────────────────────────────────
# MikroDash — Environment Variables
#
# Most settings are managed through the Settings page in the UI and saved to
# /data/settings.json on the Docker volume. The variables below are the only
# ones that need to be set here. Values for ROUTER_* and DEFAULT_IF seed the
# Settings page on first run — after that, the UI values take precedence.
# ─────────────────────────────────────────────────────────────────────────────


# Server
PORT=3081
MAX_SOCKETS=50
TRUSTED_PROXY=               # Proxy IP to trust X-Forwarded-For from (e.g. 127.0.0.1)


# Data volume & credential encryption
# Set this to a long random string to protect credentials stored in settings.json.
# If unset, a built-in default is used (not recommended for production).
DATA_SECRET=


# RouterOS — initial defaults only, can be changed in Settings UI afterwards
ROUTER_HOST=192.168.88.1
ROUTER_PORT=8729
ROUTER_TLS=true
ROUTER_TLS_INSECURE=false
ROUTER_USER=mikrodash
ROUTER_PASS=change-me
DEFAULT_IF=ether1


# Advanced — rarely changed
ROS_WRITE_TIMEOUT_MS=30000
ROS_DEBUG=false
