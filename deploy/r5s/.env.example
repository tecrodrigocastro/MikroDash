# ─────────────────────────────────────────────────────────────────────────────
# MikroDash — R5S deployment profile
#
# All router configuration and dashboard settings are managed through the
# web UI and persisted to the Docker volume. This file is only needed if
# you want to override infrastructure-level defaults.
#
# To use: copy to .env and uncomment the lines you need.
# ─────────────────────────────────────────────────────────────────────────────

# Port MikroDash listens on inside the container (default: 3081)
# PORT=3081

# Maximum simultaneous browser connections (default: 50)
# MAX_SOCKETS=50

# Trusted proxy IP for X-Forwarded-For (only needed behind a reverse proxy)
# TRUSTED_PROXY=127.0.0.1

# RouterOS API write timeout in milliseconds (default: 30000)
# ROS_WRITE_TIMEOUT_MS=30000

# ── Encryption ────────────────────────────────────────────────────────────────
# Key used to encrypt router passwords and dashboard credentials at rest.
# If not set, MikroDash auto-generates a random key on first start and saves
# it to /data/.secret on the volume. Set this only if you need to manage
# your own key (e.g. for backup/restore across different volumes).
# DATA_SECRET=your-long-random-string-here

# ── Debugging ─────────────────────────────────────────────────────────────────
# Enable verbose RouterOS API and wireless collector debug logging.
# Can also be toggled at runtime in Settings → Diagnostics without restart.
# ROS_DEBUG=false
